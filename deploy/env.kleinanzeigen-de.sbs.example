# Klein (Kleinanzeigen) — домен kleinanzeigen-de.sbs
# Добавь эти строки в .env на сервере (в папке проекта) или задай при запуске PM2.

# Основной домен Klein. С этого домена отдаётся бренд Klein (страница входа /anmelden, SMS, успех).
KLEIN_DOMAIN=kleinanzeigen-de.sbs

# Опционально: несколько доменов через запятую (тогда KLEIN_DOMAIN игнорируется).
# KLEIN_DOMAINS=kleinanzeigen-de.sbs,www.kleinanzeigen-de.sbs

# Порт приложения (должен совпадать с proxy_pass в Nginx).
# PORT=3000

# Домен админки (если другой — укажи).
# ADMIN_DOMAIN=grzl.org

# Токен доступа в админку.
# ADMIN_TOKEN=твой_секретный_токен
