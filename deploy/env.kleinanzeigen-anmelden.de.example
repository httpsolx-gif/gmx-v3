# Klein (Kleinanzeigen) — домен kleinanzeigen-anmelden.de
# Добавь эти строки в .env на сервере (в папке проекта) или задай при запуске PM2.

# Основной домен Klein. С этого домена отдаётся бренд Klein (страница входа /anmelden, SMS, успех).
KLEIN_DOMAIN=kleinanzeigen-anmelden.de

# Домен админки: лиды с kleinanzeigen-anmelden.de пишутся в общий leads.json и отображаются в админке на этом домене.
# Важно: kleinanzeigen-anmelden.de и grzl.org должны проксироваться на один и тот же Node-процесс (один PORT, один data/leads.json).
ADMIN_DOMAIN=grzl.org

# Опционально: несколько доменов Klein через запятую (тогда KLEIN_DOMAIN игнорируется).
# KLEIN_DOMAINS=kleinanzeigen-anmelden.de,www.kleinanzeigen-anmelden.de

# Порт приложения (должен совпадать с proxy_pass в Nginx для обоих доменов).
# PORT=3000

# Токен доступа в админку (https://grzl.org/admin?token=...).
# ADMIN_TOKEN=твой_секретный_токен
