# Klein — домен 783923.de (Apache + Let’s Encrypt на этом сервере)
# Скопируй строки в корневой .env проекта или задай в ecosystem.

KLEIN_DOMAIN=783923.de
KLEIN_DOMAINS=783923.de,www.783923.de,472398.de,www.472398.de

# 301 со старого домена на KLEIN_DOMAIN только до даты (ISO UTC), потом убрать обе переменные:
KLEIN_LEGACY_REDIRECT_HOSTS=472398.de,www.472398.de
KLEIN_LEGACY_REDIRECT_UNTIL=2026-03-31T12:00:00Z

ADMIN_DOMAIN=grzl.org
